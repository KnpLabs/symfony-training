{% extends 'base.html.twig' %}

{% block title %}Dinosaurs{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('css/dinosaurs.css') }}" />
{% endblock %}

{% block javascripts  %}
  <script src="{{ asset('js/bootstrap.min.js') }}"></script>
  <script src="{{ asset('js/dinosaurs.js') }}" defer></script>
{% endblock %}

{% block body %}
<main>
  <div id="alert-container">
  </div>
  <div class="list-group" id="dinosaur-list">
    {% for dinosaur in dinosaurs %}
      <a class="list-group-item list-group-item-action d-flex gap-3 py-3"
        href="{{ path('app_single_dinosaur', {id: dinosaur.id}) }}"
        data-id="{{ dinosaur.id }}"
      >
        <img
        src="{{ asset('img/dino.png') }}"
        alt="twbs"
        width="32"
        height="32"
        class="rounded-circle flex-shrink-0"
        >
        <div class="d-flex gap-2 w-100 justify-content-between">
          {{ dinosaur.name }}
        </div>
      </a>
    {% endfor %}
  </div>
</main>
<template id="dinosaur-item-template">
  <a
    class="list-group-item list-group-item-action d-flex gap-3 py-3"
    id="dinosaur-item-template-link"
  >
    <img
      src="{{ asset('img/dino.png') }}"
      alt="twbs"
      width="32"
      height="32"
      class="rounded-circle flex-shrink-0"
    />
    <div class="d-flex gap-2 w-100 justify-content-between" id="dinosaur-item-template-name">
    </div>
  </a>
</template>
{% endblock %}
